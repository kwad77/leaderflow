DATABASE_URL=postgresql://leaderflow:leaderflow@localhost:5432/leaderflow
REDIS_URL=redis://localhost:6379

# API server port
PORT=3001

# Web app URL (used by API for CORS)
WEB_URL=http://localhost:5173

# ─── AI Provider ──────────────────────────────────────────────────────────────
# Set AI_PROVIDER to one of: anthropic | openai | gemini | ollama | openrouter
# Defaults to anthropic if ANTHROPIC_API_KEY is present.
AI_PROVIDER=anthropic

# Model overrides (optional — sensible defaults apply per provider)
# AI_FAST_MODEL=   # used for per-item triage (low-latency, cheap)
# AI_SMART_MODEL=  # used for weekly automation detection (higher quality)

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI  (AI_PROVIDER=openai)
# OPENAI_API_KEY=sk-...

# Google Gemini  (AI_PROVIDER=gemini)
# GEMINI_API_KEY=...

# Ollama — local models, no API key needed  (AI_PROVIDER=ollama)
# OLLAMA_BASE_URL=http://localhost:11434

# OpenRouter — access 200+ models with one key  (AI_PROVIDER=openrouter)
# OPENROUTER_API_KEY=sk-or-...

# ─── Auth (Clerk) ─────────────────────────────────────────────────────────────
# Optional — app runs without auth in dev mode
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# ─── Integrations ─────────────────────────────────────────────────────────────
# Slack
SLACK_SIGNING_SECRET=
SLACK_BOT_TOKEN=xoxb-...

# Email webhook
EMAIL_WEBHOOK_TOKEN=

# Credential encryption key (32-byte hex string)
ENCRYPTION_KEY=

# ─── Worker config ────────────────────────────────────────────────────────────
WORKER_CONCURRENCY=3
FOLLOWUP_INTERVAL_HOURS=4
AUTOMATION_ANALYSIS_CRON=0 6 * * 1

# ─── Directory / SSO ──────────────────────────────────────────────────────────
# SCIM_BEARER_TOKEN=   (generate with: openssl rand -hex 32)
# DIRECTORY_PROVIDER=okta   or   azure   (leave unset for manual mode)
# Okta: OKTA_DOMAIN=yourcompany.okta.com  OKTA_CLIENT_ID=...  OKTA_CLIENT_SECRET=...  OKTA_API_TOKEN=...
# Azure: AZURE_TENANT_ID=...  AZURE_CLIENT_ID=...  AZURE_CLIENT_SECRET=...
# API public URL (used for OIDC redirect URI)
# API_URL=https://your-api-domain.com
