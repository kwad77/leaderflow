DATABASE_URL=postgresql://leaderflow:leaderflow@localhost:5432/leaderflow
REDIS_URL=redis://localhost:6379

# Clerk Auth — add these to enable authentication (both server and client need them)
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Vite (web app) — must have VITE_ prefix to be exposed to the browser
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# API server port
PORT=3001

# Web app URL (used by API for CORS)
WEB_URL=http://localhost:5173

# Slack Integration
SLACK_SIGNING_SECRET=
SLACK_BOT_TOKEN=xoxb-...
# (Bot Token is stored per-integration in DB config, but SIGNING_SECRET is needed for webhook verification)

# Email Integration
EMAIL_WEBHOOK_TOKEN=
# Gmail OAuth (if using gmail_oauth mode, store credentials in Integration config via API)
# GMAIL_CLIENT_ID, GMAIL_CLIENT_SECRET, GMAIL_REFRESH_TOKEN — store via POST /api/integrations

# Encryption key for integration credentials (Phase 4 — not yet implemented)
# ENCRYPTION_KEY=

# Phase 3 — AI Agents
ANTHROPIC_API_KEY=sk-ant-...
WORKER_CONCURRENCY=3
FOLLOWUP_INTERVAL_HOURS=4
AUTOMATION_ANALYSIS_CRON=0 6 * * 1
